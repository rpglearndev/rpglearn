; Engine configuration file.
; Godot 4.x

config_version=5

[application]

config/name="RPG Learn"
config/description="Learn-to-code RPG — tick-based deterministic simulation"
run/main_scene="res://scenes/debug/tick_debug.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

GameTick="*res://scripts/autoload/game_tick.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540

[rendering]

textures/canvas_textures/default_texture_filter=0
